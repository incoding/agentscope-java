# =============================================================================
# AgentScope Boba Tea Shop - Docker Environment Variables
# Configured for kimi-k2.5 model
# =============================================================================

# ============================================================================
# Image Configuration
# ============================================================================
IMAGE_REGISTRY=registry.cn-hangzhou.aliyuncs.com/agentscope
IMAGE_TAG=1.0.1

# ============================================================================
# LLM Model Configuration (Kimi K2.5 - OpenAI Compatible)
# ============================================================================
MODEL_PROVIDER=openai
MODEL_API_KEY=${MOONSHOT_API_KEY}
MODEL_NAME=kimi-k2.5
MODEL_BASE_URL=https://api.moonshot.cn/v1

# ============================================================================
# Bailian Knowledge Base Configuration (RAG)
# ============================================================================
DASHSCOPE_ACCESS_KEY_ID=${DASHSCOPE_ACCESS_KEY_ID:-}
DASHSCOPE_ACCESS_KEY_SECRET=${DASHSCOPE_ACCESS_KEY_SECRET:-}
DASHSCOPE_WORKSPACE_ID=${DASHSCOPE_WORKSPACE_ID:-}
DASHSCOPE_INDEX_ID=${DASHSCOPE_INDEX_ID:-}

# ============================================================================
# Mem0 Memory Service Configuration
# ============================================================================
MEM0_API_KEY=${MEM0_API_KEY:-}

# ============================================================================
# MySQL Configuration
# ============================================================================
MYSQL_PORT=3306
DB_NAME=multi_agent_demo
DB_USERNAME=multi_agent_demo
DB_PASSWORD=multi_agent_demo@321

# ============================================================================
# Nacos Configuration
# ============================================================================
NACOS_PORT=8848
NACOS_GRPC_PORT=9848
NACOS_CONSOLE_PORT=8080
NACOS_NAMESPACE=public
NACOS_REGISTER_ENABLED=true

# ============================================================================
# Service Port Configuration
# ============================================================================
BUSINESS_MCP_SERVER_PORT=10002
CONSULT_SUB_AGENT_PORT=10005
BUSINESS_SUB_AGENT_PORT=10006
SUPERVISOR_AGENT_PORT=10008
